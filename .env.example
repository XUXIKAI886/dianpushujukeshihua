# AI 分析功能配置
# 复制此文件为 .env.local 并填入你的实际值

# AI API Key（必需 - 用于 AI 分析报告功能）
# 推荐使用服务端变量，避免在浏览器暴露密钥
AI_API_KEY=your-api-key-here

# 兼容旧版本（不推荐，浏览器可见）
# NEXT_PUBLIC_AI_API_KEY=your-api-key-here

# AI API URL（可选 - 默认值已设置）
# 推荐使用服务端变量
# AI_API_URL=https://yunwu.ai/v1/chat/completions

# 兼容旧版本（不推荐，浏览器可见）
# NEXT_PUBLIC_AI_API_URL=https://yunwu.ai/v1/chat/completions

# ========================================
# 截图生成数据分析图功能配置
# ========================================

# Gemini API Key（必需 - 用于截图生成分析图功能）
# 获取方式：访问 yunwu.ai 获取 API Key
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# Gemini API URL（可选 - 默认值已设置）
# NEXT_PUBLIC_GEMINI_API_URL=https://yunwu.ai/v1beta/models/gemini-3-pro-image-preview:generateContent
